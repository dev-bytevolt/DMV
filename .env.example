OPENAI_API_KEY=sk-your-key-here
AI_PROVIDER=openai
OPENAI_MODEL=gpt-5.4-2026-03-05
# AI_PROVIDER=vertex
# VERTEX_PROJECT=your-gcp-project
# VERTEX_LOCATION=us-central1
# VERTEX_MODEL=gemini-3.1-pro-preview
# VERTEX_SERVICE_ACCOUNT_JSON=/path/to/service-account.json
WORKER_POOL_SIZE=5
MAX_AI_RETRIES=3
AI_RETRY_BASE_DELAY_SECONDS=5.0
ARTIFACTS_DIR=artifacts
PREPROCESS_DPI=200
# Rasterization DPI for preprocessing (clamped to 150-200)
DEBUG_MODE=false
# When true, exclude test-fixture output forms from further processing
# OPENAI_INPUT_PRICE_PER_MILLION=2.50
# OPENAI_OUTPUT_PRICE_PER_MILLION=15.00
# OPENAI_CACHED_INPUT_PRICE_PER_MILLION=0.25
