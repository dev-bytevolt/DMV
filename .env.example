OPENAI_API_KEY=sk-your-key-here
AI_PROVIDER=openai
OPENAI_MODEL=gpt-4o
WORKER_POOL_SIZE=5
MAX_AI_RETRIES=3
AI_RETRY_BASE_DELAY_SECONDS=1.0
ARTIFACTS_DIR=artifacts
PREPROCESS_DPI=200
